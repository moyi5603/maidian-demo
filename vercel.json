{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "tracking-dashboard-optimized.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/tracking-dashboard-optimized",
      "dest": "/tracking-dashboard-optimized.html"
    }
  ]
}